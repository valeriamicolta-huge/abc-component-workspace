{
  "id": "link-preview-card",
  "name": "Link Preview Card",
  "figmaNodeId": "201:58651",
  "figmaFileKey": "ILEhlPBUH6Y4lKwqSnPnSc",
  "description": "A card that displays a preview of shared links, videos, or images. Background color is extracted from the media image.",
  "contentFields": [
    "mediaImage",
    "title",
    "brand"
  ],
  "dependencies": ["read-receipt-icon"],
  "propertyVisibility": {
    "Show Play/Pause": {
      "when": {
        "Type": ["Video", "Sent links", "Received links"]
      }
    },
    "Category": {
      "when": {
        "Type": ["Video", "Image"]
      }
    },
    "Read receipt Status": {
      "when": {
        "Type": ["Sent links", "Video", "Image"],
        "Styles": ["RCS"]
      }
    }
  },
  "properties": {
    "Type": {
      "type": "VARIANT",
      "default": "Received links",
      "options": [
        "Received links",
        "Sent links",
        "Video",
        "Image"
      ]
    },
    "Styles": {
      "type": "VARIANT",
      "default": "RCS",
      "options": [
        "XMS",
        "RCS"
      ]
    },
    "Category": {
      "type": "VARIANT",
      "default": "Incoming",
      "options": [
        "Incoming",
        "Outgoing"
      ]
    },
    "Show Play/Pause": {
      "type": "BOOLEAN",
      "default": true
    },
    "Read receipt Status": {
      "type": "VARIANT",
      "default": "Read",
      "options": ["Sending", "Sent", "Delivered", "Read"]
    }
  },
  "tokens": {
    "cornerRadius": "20dp (corner-large-increased)",
    "width": "330dp",
    "mediaHeight": "187dp",
    "padding": {
      "top": 14,
      "right": 32,
      "bottom": 20,
      "left": 16
    },
    "typography": {
      "title": {
        "token": "Title Medium",
        "spec": "Google Sans Text Medium, 16/24, tracking 0"
      },
      "brand": {
        "token": "Body Small",
        "spec": "Google Sans Text Regular, 12/16, tracking 0.1"
      },
      "link": {
        "token": "Body Large",
        "spec": "Google Sans Text Regular, 16/24, tracking 0"
      }
    }
  },
