      "name": "Image",
      "desc": "Media thumbnail, top corners 20dp. Read receipt (RCS only). No play button."
    },
    {
      "name": "Video",
      "desc": "Media with play overlay, top corners 20dp. Play/Pause centered. Read receipt (RCS only)."
    },
    {
      "name": "Sent Links",
      "desc": "Link text area on top, then media with play overlay. Link bg: Primary (RCS) or Primary Container (XMS). Bottom corners 12dp."
    },
    {
      "name": "Received Links",
      "desc": "Link text area on top, then media. Link bg: Surface Container. No read receipt."
    }
