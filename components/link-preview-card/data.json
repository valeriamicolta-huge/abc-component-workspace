    ]
  ],
  "conditionalLogic": {
    "description": "The following rules govern which sub-components are rendered based on the active property combination.",
    "rules": [
      {
        "condition": "Type = Received links",
        "rendered": [
          "Link text area (Surface Container bg)",
          "Media",
          "Play/Pause button (if Show Play/Pause = true)",
          "Title",
          "Brand"
        ],
        "hidden": [
          "Read receipt",
          "Category selector"
        ]
      },
      {
        "condition": "Type = Sent links, Styles = RCS",
        "rendered": [
          "Link text area (Primary bg)",
          "Media",
          "Play/Pause button (if Show Play/Pause = true)",
          "Title",
          "Brand",
          "Read receipt"
        ],
        "hidden": [
          "Category selector"
        ]
      },
      {
        "condition": "Type = Sent links, Styles = XMS",
        "rendered": [
          "Link text area (Primary Container bg)",
          "Media",
          "Play/Pause button (if Show Play/Pause = true)",
          "Title",
          "Brand"
        ],
        "hidden": [
          "Read receipt",
          "Category selector"
        ]
      },
      {
        "condition": "Type = Video, Styles = RCS, Category = Outgoing",
        "rendered": [
          "Media",
          "Play/Pause button (always)",
          "Title",
          "Brand",
          "Read receipt"
        ],
        "hidden": []
      },
      {
        "condition": "Type = Video, Styles = RCS, Category = Incoming",
        "rendered": [
          "Media",
          "Play/Pause button (always)",
          "Title",
          "Brand"
        ],
        "hidden": [
          "Read receipt"
        ]
      },
      {
        "condition": "Type = Video, Styles = XMS",
        "rendered": [
          "Media",
          "Play/Pause button (always)",
          "Title",
          "Brand"
        ],
        "hidden": [
          "Read receipt"
        ]
      },
      {
        "condition": "Type = Image, Styles = RCS, Category = Outgoing",
        "rendered": [
          "Media",
          "Title",
          "Brand",
          "Read receipt"
        ],
        "hidden": [
          "Play/Pause button"
        ]
      },
      {
        "condition": "Type = Image, Styles = RCS, Category = Incoming",
        "rendered": [
          "Media",
          "Title",
          "Brand"
        ],
        "hidden": [
          "Play/Pause button",
          "Read receipt"
        ]
      },
      {
        "condition": "Type = Image, Styles = XMS",
        "rendered": [
          "Media",
          "Title",
          "Brand"
        ],
        "hidden": [
          "Play/Pause button",
          "Read receipt"
        ]
      }
    ]
  }
