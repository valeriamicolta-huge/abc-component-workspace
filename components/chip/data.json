    ["Label", "Short, action-oriented. Max 1 line. No punctuation."],
    ["Smart reply", "Conversational, direct response phrasing (Yes, Sure, Sounds good)."]
  ],
  "a11y": [
    ["Role", "button or checkbox (if toggleable)"],
    ["Label", "aria-label matches visible chip label"],
    ["Selected state", "aria-pressed or aria-selected for toggleable chips"],
    ["Keyboard", "Tab to focus, Space or Enter to activate"]
  ],
  "assets": [
    ["Leading icon", "18x18dp", "Inline SVG, primary color"],
    ["Avatar", "20x20dp", "From _shared/avatar shared component"]
  ],
  "conditionalLogic": {
    "description": "leadingContent applies to Smart action and Suggestion. chipCount only applies to carousel.",
    "rules": [
      {
        "condition": "type = Smart action carousel",
        "rendered": ["Scrollable chip row (chipCount chips)"],
        "hidden": ["label"]
      },
      {
        "condition": "type = Smart action, leadingContent = Icon",
        "rendered": ["Leading icon (18dp)", "Label", "Border (unselected)"],
        "hidden": []
      },
      {
        "condition": "type = Smart action, leadingContent = None",
        "rendered": ["Label", "Border (unselected)"],
        "hidden": ["Leading icon"]
      },
      {
        "condition": "type = Suggestion, leadingContent = Avatar",
        "rendered": ["Avatar (20dp)", "Label"],
        "hidden": ["Border", "Icon"]
      },
      {
        "condition": "type = Suggestion, leadingContent = Icon",
        "rendered": ["Icon (18dp)", "Label"],
        "hidden": ["Border", "Avatar"]
      },
      {
        "condition": "type = Smart reply",
        "rendered": ["Label", "Border (unselected)"],
        "hidden": ["Leading icon", "Avatar", "chipCount"]
      }
    ]
  }
