  "conditionalLogic": {
    "description": "leadingContent applies to Smart action and Suggestion. chipCount only for carousel. emoji only for Emoji type.",
    "rules": [
      { "condition": "type = Smart action carousel", "rendered": ["Scrollable chip row (chipCount chips)", "Leading content on each chip"], "hidden": ["label"] },
      { "condition": "type = Smart action, leadingContent = Icon", "rendered": ["Leading icon", "Label", "Border"], "hidden": [] },
      { "condition": "type = Smart action, leadingContent = Avatar", "rendered": ["Avatar", "Label", "Border"], "hidden": [] },
      { "condition": "type = Smart action, leadingContent = None", "rendered": ["Label", "Border"], "hidden": ["Leading"] },
      { "condition": "type = Suggestion, leadingContent = Avatar", "rendered": ["Avatar", "Label"], "hidden": ["Border"] },
      { "condition": "type = Suggestion, leadingContent = Icon", "rendered": ["Icon", "Label"], "hidden": ["Border"] },
      { "condition": "type = Smart reply", "rendered": ["Label", "Border"], "hidden": ["Leading"] },
      { "condition": "type = Emoji", "rendered": ["Emoji character"], "hidden": ["Label", "Leading", "Border"] },
      { "condition": "type = Sticker", "rendered": ["Sticker image"], "hidden": ["Label", "Leading", "Border"] }
