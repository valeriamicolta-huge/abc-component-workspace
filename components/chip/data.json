    "readReceipt": "N/A"
  },
  "states": [
    ["Unselected", "Surface bg, outline-variant border, on-surface-variant label."],
    ["Selected", "Primary-container bg, no border, on-primary-container label."],
    ["Disabled", "Reduced opacity (38%). Not interactive."]
  ],
  "darkMode": {
    "tokens": [
      ["Surface", "#FFFFFF", "#1E1F20"],
      ["Primary Container", "#D3E3FD", "#0842A0"],
      ["Outline Variant", "#C4C7C5", "#444746"],
      ["On Surface Variant", "#444746", "#C4C7C5"],
      ["On Primary Container", "#0842A0", "#D3E3FD"],
