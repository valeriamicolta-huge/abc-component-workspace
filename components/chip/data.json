    { "name": "Suggestion", "desc": "32dp height, 32dp radius. No border. Avatar or icon leading. Left 8dp with leading / right 12dp. Left 16dp without leading / right 16dp." },
    { "name": "Smart reply", "desc": "40dp height, 20dp radius. Label only, no leading content. 16dp padding both sides. Click label on canvas to edit it inline." }
  ],
  "behavior": {
    "interactive": "Tap toggles selected state (Smart action, Smart reply). Suggestion chips are non-toggle. Carousel chip count controlled via panel.",
